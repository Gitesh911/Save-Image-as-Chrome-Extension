{
  "manifest_version": 3,
  "name": "Image Save Converter",
  "version": "1.0",
  "description": "Save images as PNG or JPG",

  "permissions": [
    "contextMenus",
    "downloads"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },

  "icons": {
    "64": "icons/icon64.png"
  },

  "action": {
    "default_title": "Image Save Converter",
    "default_icon": "icons/icon64.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "imagesaveconverter@dev.local",
      "data_collection_permissions": {
        "required": [
          "none"
        ],
        "optional": []
      }
    }
  }
}